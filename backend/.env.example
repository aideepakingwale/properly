# ================================================================
# Properly — Backend Environment Variables
# ================================================================
# LOCAL DEV: cp .env.example .env  then add your free API keys.
# RENDER:    Set these in the Render dashboard Environment tab.
#            Never commit .env to git.
# ================================================================

NODE_ENV=development
PORT=3001

# ── DATABASE ──────────────────────────────────────────────────
# Local dev:   ./data/properly.db   (auto-created on first start)
# Render free: /tmp/properly.db     (resets on each redeploy)
# Render paid: /data/properly.db    (persistent disk, $7/mo plan)
DB_PATH=./data/properly.db

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=local-dev-secret-change-me-for-production
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000

# ── RATE LIMITING ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500


# ════════════════════════════════════════════════════════════════
#  AI & SPEECH KEYS — ALL FREE, NO BILLING REQUIRED
# ════════════════════════════════════════════════════════════════
#
#  The app works WITHOUT any keys:
#    - 30-pattern static phoneme cache for instant coaching
#    - Built-in template stories (phonics-correct, personalised)
#    - Browser SpeechSynthesis for TTS (Mrs. Owl's voice)
#    - Browser Web Speech API for reading recognition
#
#  Add the keys below for the full AI-powered experience — all free.
# ════════════════════════════════════════════════════════════════

# ── GOOGLE GEMINI FLASH ───────────────────────────────────────
# Primary AI: story generation + Mrs. Owl phonics coaching
# Free tier:  15 req/min · 1,500 req/day · NO billing, NO credit card
# Get key:    https://aistudio.google.com/app/apikey  (~60 seconds)
GEMINI_API_KEY=

# ── GROQ (LLAMA 3.1) ─────────────────────────────────────────
# Backup AI: story generation + coaching when Gemini limit is reached
# Model:      llama-3.1-8b-instant (coaching) / llama-3.1-70b-versatile (stories)
# Free tier:  30 req/min · 14,400 req/day · NO billing, NO credit card
# Get key:    https://console.groq.com/keys  (~60 seconds, instant signup)
GROQ_API_KEY=

# ── AZURE COGNITIVE SERVICES SPEECH ──────────────────────────
# Pronunciation Assessment (phoneme-level scoring) + Neural TTS voice
# Free F0:   5 audio hours/month (STT) + 500,000 characters/month (TTS)
# Voice:     en-GB-SoniaNeural — warm, natural UK English
# Setup:     https://portal.azure.com → Create resource → Speech → Free F0
# Regions:   uksouth | westeurope | eastus | australiaeast
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=uksouth

# ── EMAIL (SMTP) ──────────────────────────────────────────────
# Used for: email verification on registration
# Without these, registration still works but skips email verification.
#
# Option A — Gmail (recommended, free, 500 emails/day)
#   1. Enable 2FA on Google account
#   2. myaccount.google.com → Security → App passwords → Mail
#   3. Use the 16-char App Password below (NOT your Gmail password)
SMTP_PROVIDER=gmail
SMTP_USER=your.email@gmail.com
SMTP_PASS=abcd efgh ijkl mnop

# Option B — Outlook/Hotmail
# SMTP_PROVIDER=outlook
# SMTP_USER=your.email@outlook.com
# SMTP_PASS=your-password

# Option C — Brevo/SendinBlue (300 free emails/day)
# SMTP_PROVIDER=brevo
# SMTP_USER=your.email@example.com
# SMTP_PASS=your-brevo-smtp-key

# Your app's public URL (used in email links)
# Local:  APP_URL=http://localhost:5173
# Render: APP_URL=https://properly-web.onrender.com
APP_URL=http://localhost:5173
SMTP_FROM_NAME=Properly Phonics

# ── SOCIAL LOGIN (OAUTH) ──────────────────────────────────────
# The backend's own URL (used as the OAuth redirect base)
API_URL=http://localhost:3001

# Google OAuth — free
# Setup: console.cloud.google.com → APIs & Services → Credentials
#   1. Create OAuth 2.0 Client ID → Web Application
#   2. Authorised redirect URI: http://localhost:3001/api/auth/google/callback
#   3. For production: https://properly-api.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth — free
# Setup: developers.facebook.com → My Apps → Create App → Consumer
#   1. Add Facebook Login product
#   2. Valid OAuth redirect URI: http://localhost:3001/api/auth/facebook/callback
#   3. For production: https://properly-api.onrender.com/api/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
