{
  "name": "properly-api",
  "version": "2.0.0",
  "description": "Properly AI Phonics Tutor — Backend REST API (uses built-in node:sqlite, no native compilation)",
  "type": "module",
  "main": "src/app.js",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node --no-warnings=ExperimentalWarning src/app.js",
    "dev": "nodemon --watch src --ext js --exec \"node --no-warnings=ExperimentalWarning\" src/app.js",
    "seed": "node --no-warnings=ExperimentalWarning src/db/seed.js",
    "migrate": "node --no-warnings=ExperimentalWarning src/db/migrate.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "@google/generative-ai": "^0.17.1",
    "uuid": "^9.0.1",
    "nodemailer": "^6.9.13",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-facebook": "^3.0.0",
    "express-session": "^1.18.0",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
